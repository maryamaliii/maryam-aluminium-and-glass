generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum ServiceCategory {
  MIRRORS
  KITCHEN
  WARDROBES
  CUSTOM_FABRICATION
  WINDOWS_DOORS
  PARTITIONS
  FIXTURES
  INSTALLATION
}

enum SubmissionStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model Service {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  description String
  category    ServiceCategory
  icon        String
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  images        ServiceImage[]
  projects      Project[]
  quoteRequests QuoteRequest[]
}

model ServiceImage {
  id        String  @id @default(cuid())
  serviceId String
  url       String
  alt       String?
  sortOrder Int     @default(0)

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  serviceId   String
  image       String
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([isFeatured])
}

model ContactSubmission {
  id        String           @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())
  readAt    DateTime?
  notes     String?

  @@index([status])
  @@index([createdAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  clientName String
  company   String?
  role      String?
  content   String
  rating    Int      @default(5)
  avatar    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("testimonials")
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("faqs")
}

enum QuoteStatus {
  NEW
  QUOTE_SENT
  NEGOTIATING
  WON
  LOST
}

model QuoteRequest {
  id            String      @id @default(cuid())
  clientName    String
  email         String
  phone         String
  serviceId     String?
  service       Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  projectScope  String
  timeline      String?
  location      String?
  budget        String?
  status        QuoteStatus @default(NEW)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("quote_requests")
}
